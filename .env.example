# Google OAuth Client ID — get one from https://console.cloud.google.com/apis/credentials
# Required scopes: openid, email, profile, https://www.googleapis.com/auth/drive.appdata
# Authorized origins: http://localhost:5173 (dev), https://<username>.github.io (prod)
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id-here
